# ── Secrets (NEVER commit) ───────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ── Python / backend ─────────────────────────────────────
zeva-backend/venv/
**/venv/
**/__pycache__/
*.pyc

# ── Local data stores (regenerable) ──────────────────────
zeva-backend/chroma_db/
**/chroma_db/
*.db
*.sqlite
*.sqlite3

# ── Frontend (fortend/) is part of this monorepo now. Its own
#    fortend/.gitignore still excludes node_modules/.next/.env* there. ──

# ── Local agent/tooling artifacts (not product code) ─────
**/.claude/
**/skills-lock.json

# ── OS / editor cruft ────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.log
