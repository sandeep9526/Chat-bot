# Isko copy karke ".env" banao aur apni asli key daalo.
# (.env git me commit NAHI hota — .gitignore me hai.)

# OpenRouter key: openrouter.ai > Keys > Create Key  (sk-or-v1-...)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# (optional) koi bhi free model — openrouter.ai/models me ":free" waale
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# (No CORS_ORIGINS: this API intentionally uses wildcard CORS without
# credentials — see the comment above app.add_middleware(CORSMiddleware...)
# in main.py for why that's safe here and why a static allowlist doesn't
# work for a multi-tenant widget embedded on arbitrary client domains.)

# Neon Postgres — TWO connection strings, two different roles:
#   DATABASE_URL     = neondb_owner (BYPASSRLS) — schema.sql / migrations ONLY.
#   APP_DATABASE_URL = zeva_app (NOBYPASSRLS)   — what this backend actually
#                       runs as; Row-Level Security only actually applies
#                       under this role (see schema.sql's comments + the
#                       ONBOARDING.md role-creation step for a fresh env).
DATABASE_URL=postgresql://neondb_owner:password@ep-xxxx.neon.tech/dbname?sslmode=require
APP_DATABASE_URL=postgresql://zeva_app:password@ep-xxxx.neon.tech/dbname?sslmode=require

# Better Auth (Next.js app) base URL — used to fetch its JWKS endpoint for
# verifying JWTs on incoming requests. Point at the real deployed frontend
# origin in production.
BETTER_AUTH_BASE_URL=http://localhost:3000

# Platform admin — comma-separated emails allowed into the superadmin panel
# (/superadmin/*, sees every tenant). Empty/unset = nobody, fail-closed.
# PLATFORM_ADMIN_EMAILS=you@example.com

# Paddle — only needed once a real Paddle account/webhook exists (see
# billing.py's module docstring for setup steps). Until set, the webhook
# endpoint fails closed (rejects everything) rather than silently accepting.
# PADDLE_WEBHOOK_SECRET=pdl_ntfset_...

# Error tracking — sentry.io > New Project > FastAPI. Verified no-op with
# no DSN set (sentry_sdk.init(dsn=None) raises nothing, just never reports).
# SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
