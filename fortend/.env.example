# Isko copy karke ".env.local" banao (local dev ke liye), aur Vercel par
# ye SAAT vars "Project → Settings → Environment Variables" me daalo.
# (.env.local git me commit NAHI hota — .gitignore me hai. Ye .example safe hai.)

# ── Backend API (FastAPI on Render/Railway) ──────────────────────────
# Local: http://127.0.0.1:8000 | Prod: aapka LIVE backend URL (Render).
# NEXT_PUBLIC_* build-time pe bake hota hai → change karo to Vercel pe REDEPLOY.
NEXT_PUBLIC_API_URL=https://zeva-backend-xxxx.onrender.com

# ── Is frontend ka apna public URL ───────────────────────────────────
# Local: http://localhost:3000 | Prod: https://<aapka-project>.vercel.app
# Better Auth isko baseURL / issuer / trustedOrigin ke liye use karta hai.
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# ── Better Auth ──────────────────────────────────────────────────────
# SECRET: ek lamba random string (openssl rand -base64 32). Local wali hi
# reuse kar sakte ho, ya prod ke liye nayi generate karo.
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
# URL: same as NEXT_PUBLIC_APP_URL (prod domain). OAuth callback isi pe banta hai:
#   {BETTER_AUTH_URL}/api/auth/callback/google
BETTER_AUTH_URL=https://your-project.vercel.app

# ── Database (Neon Postgres) — Better Auth ki user/session tables ────
# Backend jo DATABASE_URL use karta hai, wahi same Neon DB yahan bhi.
DATABASE_URL=postgresql://neondb_owner:password@ep-xxxx.neon.tech/dbname?sslmode=verify-full

# ── Google OAuth (sign-in with Google) ───────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth client.
# Deploy ke baad Authorized redirect URI me ye add karna NA bhoolo:
#   https://<aapka-vercel-domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxx

# ── (optional) Sentry error tracking — khaali chhoda to no-op ────────
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
# NEXT_PUBLIC_SENTRY_DSN=
